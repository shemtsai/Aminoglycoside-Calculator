<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.1//EN"
  "http://www.w3.org/TR/xhtml11/DTD/xhtml11.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Aminoglycoside PK Calculator</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<!--
  FIX #1 — CRITICAL: All bare & in the Google Fonts query-string replaced with &amp;
  Original:  ...wght@400;500&family=Libre...&family=DM+Sans...&display=swap
  Corrected: ...wght@400;500&amp;family=Libre...&amp;family=DM+Sans...&amp;display=swap
-->
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&amp;family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&amp;family=DM+Sans:wght@300;400;500;600&amp;display=swap" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<!--
  FIX #2 — CRITICAL: <style> content wrapped in XML CDATA comment so an XML parser
  never attempts to tokenise CSS selector characters as XML markup.
  The  /*<![CDATA[*/  /  /*]]>*/  wrapper is invisible to both CSS engines and
  HTML5 parsers while satisfying the XHTML/XML requirement.
-->
<style>
/*<![CDATA[*/
  :root {
    --bg:        #f0f4f8;
    --surface:   #ffffff;
    --border:    #dce4ef;
    --primary:   #1a3a5c;
    --accent:    #0e7490;
    --accent2:   #06b6d4;
    --text:      #1e293b;
    --muted:     #64748b;
    --success:   #0d7a5f;
    --radius:    12px;
    --shadow:    0 2px 16px rgba(14,116,144,0.08);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    padding: 0 0 60px;
  }

  header {
    background: var(--primary);
    color: #fff;
    padding: 28px 40px 24px;
    border-bottom: 3px solid var(--accent2);
    display: flex;
    align-items: baseline;
    gap: 16px;
  }
  header h1 {
    font-family: 'Libre Baskerville', serif;
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  header span.sub {
    font-size: 0.8rem;
    font-family: 'DM Mono', monospace;
    color: var(--accent2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .tab-bar {
    background: var(--primary);
    display: flex;
    gap: 4px;
    padding: 0 40px;
  }
  .tab-btn {
    padding: 10px 22px;
    background: none;
    border: none;
    color: rgba(255,255,255,0.55);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.88rem;
    font-weight: 500;
    cursor: pointer;
    border-bottom: 3px solid transparent;
    transition: color .2s, border-color .2s;
    letter-spacing: 0.03em;
  }
  .tab-btn.active { color: #fff; border-bottom-color: var(--accent2); }
  .tab-btn:hover:not(.active) { color: rgba(255,255,255,.8); }

  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  .container { max-width: 1160px; margin: 0 auto; padding: 32px 24px 0; }
  .grid-2 { display: grid; grid-template-columns: 340px 1fr; gap: 24px; }

  @media (max-width: 760px) {
    .grid-2 { grid-template-columns: 1fr; }
    header { padding: 20px 20px 16px; }
    .tab-bar { padding: 0 20px; }
    .container { padding: 20px 14px 0; }
  }

  .card {
    background: var(--surface);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    padding: 24px;
    box-shadow: var(--shadow);
  }
  .card h3 {
    font-family: 'Libre Baskerville', serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 18px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .card h3 .dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--accent2);
    flex-shrink: 0;
  }

  .form-group { margin-bottom: 14px; }
  label {
    display: block;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--muted);
    margin-bottom: 5px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  input[type="number"], input[type="date"], input[type="time"], select {
    width: 100%;
    padding: 9px 12px;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    color: var(--text);
    background: #fafbfd;
    transition: border-color .2s, box-shadow .2s;
    outline: none;
  }
  input:focus, select:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(14,116,144,0.12);
    background: #fff;
  }
  .row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

  .radio-group {
    display: flex;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 16px;
  }
  .radio-group label {
    flex: 1;
    margin: 0;
    padding: 8px 6px;
    text-align: center;
    cursor: pointer;
    font-size: 0.73rem;
    font-weight: 600;
    color: var(--muted);
    background: #fafbfd;
    border: none;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    transition: background .15s, color .15s;
    line-height: 1.3;
  }
  .radio-group input[type="radio"] { display: none; }
  .radio-group input[type="radio"]:checked + label { background: var(--accent); color: #fff; }

  .btn {
    width: 100%;
    padding: 11px;
    border: none;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 0.02em;
    transition: transform .1s, box-shadow .15s, background .15s;
  }
  .btn:active { transform: scale(0.98); }
  .btn-primary { background: var(--accent); color: #fff; box-shadow: 0 2px 8px rgba(14,116,144,0.25); }
  .btn-primary:hover { background: #0e6480; box-shadow: 0 4px 14px rgba(14,116,144,0.35); }
  .btn-success { background: var(--success); color: #fff; box-shadow: 0 2px 8px rgba(13,122,95,0.2); margin-top: 8px; }
  .btn-success:hover { background: #0a6650; }

  .results-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 4px;
  }
  .result-item {
    background: #f6f9fc;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px 14px;
  }
  .result-item .r-label { font-size: 0.7rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px; }
  .result-item .r-value { font-family: 'DM Mono', monospace; font-size: 1.15rem; font-weight: 500; color: var(--accent); }
  .result-item .r-unit { font-size: 0.72rem; color: var(--muted); margin-top: 1px; }
  .result-item.highlight { border-color: var(--accent2); background: #ecfeff; }
  .result-item.highlight .r-value { color: var(--primary); }

  .results-empty { text-align: center; color: var(--muted); font-size: 0.85rem; padding: 32px 0; font-style: italic; }

  .chart-wrap { position: relative; height: 280px; }

  #toast {
    position: fixed;
    bottom: 28px; right: 28px;
    background: var(--primary);
    color: #fff;
    padding: 12px 20px;
    border-radius: 10px;
    font-size: 0.84rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.22);
    opacity: 0;
    transform: translateY(12px);
    transition: opacity .3s, transform .3s;
    pointer-events: none;
    max-width: 340px;
    z-index: 9999;
  }
  #toast.show { opacity: 1; transform: translateY(0); }

  .conditional { display: none; }
  .conditional.visible { display: block; }

  /* ── Equations panel ─────────────────────────────── */
  .eq-toggle-wrap { margin-bottom: 18px; }

  .eq-toggle-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 8px;
    padding: 9px 18px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.83rem;
    font-weight: 600;
    color: var(--accent);
    cursor: pointer;
    letter-spacing: 0.03em;
    transition: background .15s, border-color .15s;
    box-shadow: var(--shadow);
  }
  .eq-toggle-btn:hover { background: #ecfeff; border-color: var(--accent2); }
  .eq-toggle-btn .arrow { font-size: 0.65rem; transition: transform .25s; display: inline-block; }
  .eq-toggle-btn.open .arrow { transform: rotate(180deg); }

  .eq-panel {
    display: none;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 26px 28px 22px;
    margin-top: 12px;
  }
  .eq-panel.open { display: block; }

  .eq-section-title {
    font-family: 'Libre Baskerville', serif;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 20px 0 12px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border);
  }
  .eq-section-title:first-child { margin-top: 0; }

  .eq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
    gap: 10px;
  }

  .eq-item {
    background: #f6f9fc;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 13px 15px;
  }
  .eq-item .eq-name {
    font-size: 0.69rem;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-bottom: 9px;
  }
  .eq-item .eq-body {
    font-family: 'DM Mono', monospace;
    font-size: 0.85rem;
    color: var(--primary);
    line-height: 2;
  }
  /* fraction helper */
  .frac {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    vertical-align: middle;
    margin: 0 2px;
    line-height: 1.25;
    font-size: 0.8rem;
  }
  .frac .num { border-bottom: 1.5px solid var(--primary); padding: 0 3px 1px; }
  .frac .den { padding: 1px 3px 0; }
  .eq-item .eq-note {
    font-size: 0.69rem;
    color: var(--muted);
    margin-top: 7px;
    line-height: 1.55;
    font-family: 'DM Sans', sans-serif;
  }

  footer {
    margin-top: 48px;
    text-align: center;
    color: var(--muted);
    font-size: 0.77rem;
    padding: 0 20px;
    line-height: 1.7;
  }
  footer a { color: var(--accent); text-decoration: none; }
  footer a:hover { text-decoration: underline; }
/*]]>*/
</style>
</head>
<body>

<header>
  <div>
    <h1>Aminoglycoside Calculator</h1>
    <span class="sub">Pharmacokinetic Dosing Tool</span>
  </div>
</header>

<div class="tab-bar">
  <button class="tab-btn active" onclick="switchTab('pk', this)">Standard PK Calculator</button>
  <button class="tab-btn" onclick="switchTab('opt', this)">Dose Optimization</button>
</div>

<!-- ════════════ TAB 1 ════════════ -->
<div id="tab-pk" class="tab-panel active">
<div class="container">

  <!-- Equations toggle -->
  <div class="eq-toggle-wrap">
    <button class="eq-toggle-btn" id="eq-btn-pk" onclick="toggleEq('pk')">
      <span id="eq-btn-pk-label">Show PK Equations</span>
      <span class="arrow">&#9660;</span>
    </button>
    <div class="eq-panel" id="eq-panel-pk">

      <div class="eq-section-title">Parameter Estimation from Two Levels</div>
      <div class="eq-grid">

        <div class="eq-item">
          <div class="eq-name">Elimination Rate Constant (k<sub>e</sub>)</div>
          <div class="eq-body">
            k<sub>e</sub> =
            <span class="frac"><span class="num">ln(C&#8321; / C&#8322;)</span><span class="den">t&#8322; &#8722; t&#8321;</span></span>
          </div>
          <div class="eq-note">t&#8321;, t&#8322; = hours after <em>start</em> of infusion</div>
        </div>

        <div class="eq-item">
          <div class="eq-name">Elimination Half-Life (t<sub>&#189;</sub>)</div>
          <div class="eq-body">
            t<sub>&#189;</sub> =
            <span class="frac"><span class="num">0.693</span><span class="den">k<sub>e</sub></span></span>
          </div>
        </div>

        <div class="eq-item">
          <div class="eq-name">Extrapolated Peak (C<sub>max</sub>)</div>
          <div class="eq-body">
            C<sub>max</sub> =
            <span class="frac"><span class="num">C&#8321;</span><span class="den">e<sup>&#8722;k<sub>e</sub>(t&#8321; &#8722; t&#8242;)</sup></span></span>
          </div>
          <div class="eq-note">t&#8242; = infusion duration (hr)</div>
        </div>

        <div class="eq-item">
          <div class="eq-name">Extrapolated Trough (C<sub>min</sub>)</div>
          <div class="eq-body">
            C<sub>min</sub> = C<sub>max</sub> &#183; e<sup>&#8722;k<sub>e</sub>(&#964; &#8722; t&#8242;)</sup>
          </div>
          <div class="eq-note">&#964; = dosing interval (hr)</div>
        </div>

        <div class="eq-item">
          <div class="eq-name">Volume of Distribution (V<sub>d</sub>)</div>
          <div class="eq-body">
            V<sub>d</sub> =
            <span class="frac">
              <span class="num">(Dose/t&#8242;) &#183; (1 &#8722; e<sup>&#8722;k<sub>e</sub>t&#8242;</sup>)</span>
              <span class="den">C<sub>max</sub> &#183; k<sub>e</sub> &#183; (1 &#8722; e<sup>&#8722;k<sub>e</sub>&#964;</sup>)</span>
            </span>
          </div>
        </div>

        <div class="eq-item">
          <div class="eq-name">Clearance (Cl<sub>r</sub>)</div>
          <div class="eq-body">
            Cl<sub>r</sub> = V<sub>d</sub> &#183; k<sub>e</sub>
          </div>
          <div class="eq-note">L/hr &#8212; multiply by 16.67 for mL/min</div>
        </div>

        <div class="eq-item">
          <div class="eq-name">AUC&#8324;</div>
          <div class="eq-body">
            AUC<sub>24</sub> =
            <span class="frac"><span class="num">Dose</span><span class="den">k<sub>e</sub> &#183; V<sub>d</sub></span></span>
            &#183;
            <span class="frac"><span class="num">24</span><span class="den">&#964;</span></span>
          </div>
          <div class="eq-note">mg&#183;h/L</div>
        </div>

      </div>
    </div>
  </div><!-- /eq-toggle-wrap -->

  <div class="grid-2">

    <!-- LEFT -->
    <div>
      <div class="card">
        <h3><span class="dot"></span>Input Parameters</h3>

        <div class="radio-group">
          <input type="radio" id="m-ct" name="method" value="ct" checked="checked" onchange="toggleMethod()" />
          <label for="m-ct">Concentrations &amp; Times</label>
          <input type="radio" id="m-dt" name="method" value="dt" onchange="toggleMethod()" />
          <label for="m-dt">Date / Time / Dose</label>
        </div>

        <div id="section-ct" class="conditional visible">
          <div class="row-2">
            <div class="form-group">
              <label>C&#8321; &#8212; First Level (mg/L)</label>
              <input type="number" id="c1" value="8" min="0" step="0.1" />
            </div>
            <div class="form-group">
              <label>C&#8322; &#8212; Second Level (mg/L)</label>
              <input type="number" id="c2" value="1" min="0" step="0.1" />
            </div>
          </div>
          <div class="row-2">
            <div class="form-group">
              <label>t&#8321; &#8212; Time of C&#8321; after start of infusion (hr)</label>
              <input type="number" id="t1" value="4" min="0" step="0.1" />
            </div>
            <div class="form-group">
              <label>t&#8322; &#8212; Time of C&#8322; after start of infusion (hr)</label>
              <input type="number" id="t2" value="12" min="0" step="0.1" />
            </div>
          </div>
        </div>

        <div id="section-dt" class="conditional">
          <div class="row-2">
            <div class="form-group">
              <label>Dose Date</label>
              <input type="date" id="dose_date" />
            </div>
            <div class="form-group">
              <label>Dose Time</label>
              <input type="time" id="dose_time" value="08:00" />
            </div>
          </div>
          <div class="row-2">
            <div class="form-group">
              <label>Date of C&#8321;</label>
              <input type="date" id="date1" />
            </div>
            <div class="form-group">
              <label>Time of C&#8321;</label>
              <input type="time" id="time1" value="12:00" />
            </div>
          </div>
          <div class="form-group">
            <label>C&#8321; Concentration (mg/L)</label>
            <input type="number" id="c1_date" value="8" min="0" step="0.1" />
          </div>
          <div class="row-2">
            <div class="form-group">
              <label>Date of C&#8322;</label>
              <input type="date" id="date2" />
            </div>
            <div class="form-group">
              <label>Time of C&#8322;</label>
              <input type="time" id="time2" value="20:00" />
            </div>
          </div>
          <div class="form-group">
            <label>C&#8322; Concentration (mg/L)</label>
            <input type="number" id="c2_date" value="1" min="0" step="0.1" />
          </div>
        </div>

        <div class="row-2">
          <div class="form-group">
            <label>Infusion Duration t&#8242; (hr)</label>
            <input type="number" id="t_inf" value="1" min="0" step="0.1" />
          </div>
          <div class="form-group">
            <label>Dosing Interval &#964; (hr)</label>
            <input type="number" id="tau" value="24" min="1" step="0.1" />
          </div>
        </div>
        <div class="form-group">
          <label>Total Dose (mg)</label>
          <input type="number" id="dose" value="1000" min="1" step="1" />
        </div>

        <button class="btn btn-primary" onclick="calculatePK()">Calculate PK Parameters</button>
        <button class="btn btn-success" onclick="useInOptimization()">Use Results in Optimization &#8594;</button>
      </div>
    </div>

    <!-- RIGHT -->
    <div style="display:flex;flex-direction:column;gap:20px;">
      <div class="card">
        <h3><span class="dot"></span>Calculated PK Parameters</h3>
        <div id="pk-results"><p class="results-empty">Enter values and click Calculate to see results.</p></div>
      </div>
      <div class="card">
        <h3><span class="dot"></span>Concentration&#8211;Time Curve</h3>
        <div class="chart-wrap"><canvas id="pkChart"></canvas></div>
      </div>
    </div>

  </div>
</div>
</div><!-- /tab-pk -->

<!-- ════════════ TAB 2 ════════════ -->
<div id="tab-opt" class="tab-panel">
<div class="container">

  <!-- Equations toggle -->
  <div class="eq-toggle-wrap">
    <button class="eq-toggle-btn" id="eq-btn-opt" onclick="toggleEq('opt')">
      <span id="eq-btn-opt-label">Show Optimization Equations</span>
      <span class="arrow">&#9660;</span>
    </button>
    <div class="eq-panel" id="eq-panel-opt">

      <div class="eq-section-title">Predicted Concentrations from Dose</div>
      <div class="eq-grid">

        <div class="eq-item">
          <div class="eq-name">Predicted Peak (C<sub>max</sub>)</div>
          <div class="eq-body">
            C<sub>max</sub> =
            <span class="frac"><span class="num">Dose</span><span class="den">V<sub>d</sub> &#183; k<sub>e</sub> &#183; t&#8242;</span></span>
            &#183; (1 &#8722; e<sup>&#8722;k<sub>e</sub>t&#8242;</sup>)
          </div>
        </div>

        <div class="eq-item">
          <div class="eq-name">Predicted Trough (C<sub>min</sub>)</div>
          <div class="eq-body">
            C<sub>min</sub> = C<sub>max</sub> &#183; e<sup>&#8722;k<sub>e</sub>(&#964; &#8722; t&#8242;)</sup>
          </div>
        </div>

        <div class="eq-item">
          <div class="eq-name">Predicted AUC&#8324;</div>
          <div class="eq-body">
            AUC<sub>24</sub> =
            <span class="frac"><span class="num">Dose</span><span class="den">k<sub>e</sub> &#183; V<sub>d</sub></span></span>
            &#183;
            <span class="frac"><span class="num">24</span><span class="den">&#964;</span></span>
          </div>
        </div>

      </div>

      <div class="eq-section-title">Back-Calculation: Dose from Target</div>
      <div class="eq-grid">

        <div class="eq-item">
          <div class="eq-name">Dose from AUC Target</div>
          <div class="eq-body">
            Dose = AUC<sub>24,target</sub> &#183; k<sub>e</sub> &#183; V<sub>d</sub> &#183;
            <span class="frac"><span class="num">&#964;</span><span class="den">24</span></span>
          </div>
          <div class="eq-note">Rearrangement of the AUC&#8324; equation above</div>
        </div>

        <div class="eq-item">
          <div class="eq-name">Dose from Peak Target</div>
          <div class="eq-body">
            Dose =
            <span class="frac">
              <span class="num">C<sub>max,target</sub> &#183; V<sub>d</sub> &#183; k<sub>e</sub> &#183; t&#8242;</span>
              <span class="den">1 &#8722; e<sup>&#8722;k<sub>e</sub>t&#8242;</sup></span>
            </span>
          </div>
          <div class="eq-note">Rearrangement of the predicted peak equation above</div>
        </div>

      </div>
    </div>
  </div><!-- /eq-toggle-wrap -->

  <div class="grid-2">

    <!-- LEFT -->
    <div>
      <div class="card">
        <h3><span class="dot"></span>Patient PK Parameters</h3>

        <div class="row-2">
          <div class="form-group">
            <label>Ke (hr&#8315;&#185;)</label>
            <input type="number" id="ke_opt" value="0.3" min="0" step="0.001" />
          </div>
          <div class="form-group">
            <label>Vd (L)</label>
            <input type="number" id="vd_opt" value="20" min="0" step="0.1" />
          </div>
        </div>
        <div class="row-2">
          <div class="form-group">
            <label>Infusion Duration t&#8242; (hr)</label>
            <input type="number" id="t_inf_opt" value="1" min="0" step="0.1" />
          </div>
          <div class="form-group">
            <label>Dosing Interval &#964; (hr)</label>
            <input type="number" id="interval_opt" value="24" min="0" step="0.1" />
          </div>
        </div>

        <div class="form-group">
          <label>Calculation Mode</label>
          <select id="calc_mode" onchange="toggleCalcMode()">
            <option value="auc">Calculate from AUC Target</option>
            <option value="peak">Calculate from Peak Target</option>
            <option value="dose">Calculate from Dose</option>
          </select>
        </div>

        <div id="auc-input" class="conditional visible">
          <div class="form-group">
            <label>Target AUC&#8324; (mg&#183;h/L)</label>
            <input type="number" id="target_auc" value="250" min="0" step="1" />
          </div>
        </div>
        <div id="peak-input" class="conditional">
          <div class="form-group">
            <label>Target Peak C<sub>max</sub> (mg/L)</label>
            <input type="number" id="target_cmax" value="10" min="0" step="0.1" />
          </div>
        </div>
        <div id="dose-input" class="conditional">
          <div class="form-group">
            <label>Dose (mg)</label>
            <input type="number" id="input_dose" value="1000" min="1" step="1" />
          </div>
        </div>

        <button class="btn btn-primary" onclick="optimizeDose()">Calculate</button>
      </div>
    </div>

    <!-- RIGHT -->
    <div style="display:flex;flex-direction:column;gap:20px;">
      <div class="card">
        <h3><span class="dot"></span>Optimization Results</h3>
        <div id="opt-results"><p class="results-empty">Enter parameters and click Calculate.</p></div>
      </div>
      <div class="card">
        <h3><span class="dot"></span>Predicted Concentration&#8211;Time Curve</h3>
        <div class="chart-wrap"><canvas id="optChart"></canvas></div>
      </div>
    </div>

  </div>
</div>
</div><!-- /tab-opt -->

<div id="toast"></div>

<footer>
