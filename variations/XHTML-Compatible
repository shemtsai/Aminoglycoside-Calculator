<!--
  FIX #3 — CRITICAL: All JavaScript wrapped in //<![CDATA[ ... //]]>
  Without this, an XML parser tokenises the script body as markup and chokes on:
    • <= and => operators  (bare < / > characters)
    • HTML tag strings inside template literals passed to .innerHTML
    • The literal string "> 0" in the toast call
  The //  line-comment prefix/suffix makes the CDATA delimiters invisible
  to ordinary JavaScript engines (treated as comments), so the script
  executes identically in HTML5 browsers while satisfying XML parsing rules.
-->
<script>
//<![CDATA[
// ─────────────────────────────────────────────────
// State
// ─────────────────────────────────────────────────
var pkChartInstance  = null;
var optChartInstance = null;
var storedPK = {};

// ─────────────────────────────────────────────────
// Helpers
// ─────────────────────────────────────────────────
function toast(msg, dur) {
  dur = dur || 4000;
  var el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  setTimeout(function() { el.classList.remove('show'); }, dur);
}
function v(id)  { return parseFloat(document.getElementById(id).value); }
function sv(id) { return document.getElementById(id).value; }

function linspace(start, end, n) {
  n = n || 300;
  var arr = [], step = (end - start) / (n - 1);
  for (var i = 0; i < n; i++) arr.push(start + i * step);
  return arr;
}

// ─────────────────────────────────────────────────
// Tab switching
// ─────────────────────────────────────────────────
function switchTab(tab, btn) {
  document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('active'); });
  document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
  document.getElementById('tab-' + tab).classList.add('active');
  btn.classList.add('active');
}

// ─────────────────────────────────────────────────
// Equations toggle
// ─────────────────────────────────────────────────
function toggleEq(which) {
  var btn   = document.getElementById('eq-btn-' + which);
  var panel = document.getElementById('eq-panel-' + which);
  var lbl   = document.getElementById('eq-btn-' + which + '-label');
  var isOpen = panel.classList.toggle('open');
  btn.classList.toggle('open', isOpen);
  if (which === 'pk') {
    lbl.textContent = isOpen ? 'Hide PK Equations' : 'Show PK Equations';
  } else {
    lbl.textContent = isOpen ? 'Hide Optimization Equations' : 'Show Optimization Equations';
  }
}

// ─────────────────────────────────────────────────
// Conditional inputs
// ─────────────────────────────────────────────────
function toggleMethod() {
  var method = document.querySelector('input[name="method"]:checked').value;
  document.getElementById('section-ct').classList.toggle('visible', method === 'ct');
  document.getElementById('section-dt').classList.toggle('visible', method === 'dt');
}

function toggleCalcMode() {
  var mode = sv('calc_mode');
  document.getElementById('auc-input').classList.toggle('visible',  mode === 'auc');
  document.getElementById('peak-input').classList.toggle('visible', mode === 'peak');
  document.getElementById('dose-input').classList.toggle('visible', mode === 'dose');
}

// ─────────────────────────────────────────────────
// Date defaults
// ─────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', function() {
  var today = new Date().toISOString().split('T')[0];
  ['dose_date','date1','date2'].forEach(function(id) {
    document.getElementById(id).value = today;
  });
});

// ─────────────────────────────────────────────────
// Chart helper
// ─────────────────────────────────────────────────
function renderChart(canvasId, old, datasets, xLabel, yLabel) {
  if (old) old.destroy();
  return new Chart(document.getElementById(canvasId).getContext('2d'), {
    type: 'line',
    data: { datasets: datasets },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { labels: { font: { family: 'DM Sans', size: 12 }, color: '#475569' } }
      },
      scales: {
        x: {
          type: 'linear',
          title: { display: true, text: xLabel, font: { family: 'DM Sans', size: 12 }, color: '#64748b' },
          grid: { color: '#e2e8f0' },
          ticks: { font: { family: 'DM Mono', size: 11 }, color: '#64748b' }
        },
        y: {
          title: { display: true, text: yLabel, font: { family: 'DM Sans', size: 12 }, color: '#64748b' },
          grid: { color: '#e2e8f0' },
          ticks: { font: { family: 'DM Mono', size: 11 }, color: '#64748b' },
          beginAtZero: true
        }
      }
    }
  });
}

// ─────────────────────────────────────────────────
// Standard PK Calculator
// ─────────────────────────────────────────────────
function calculatePK() {
  var method = document.querySelector('input[name="method"]:checked').value;
  var t_inf  = v('t_inf');
  var tau    = v('tau');
  var dose   = v('dose');

  var ke, c1_val, c2_val, t1_val, t2_val;

  if (method === 'ct') {
    c1_val = v('c1');  c2_val = v('c2');
    t1_val = v('t1');  t2_val = v('t2');
  } else {
    var doseDateTime = new Date(sv('dose_date') + 'T' + sv('dose_time'));
    var dt1 = new Date(sv('date1') + 'T' + sv('time1'));
    var dt2 = new Date(sv('date2') + 'T' + sv('time2'));
    t1_val = (dt1 - doseDateTime) / 3600000;
    t2_val = (dt2 - doseDateTime) / 3600000;
    c1_val = v('c1_date');
    c2_val = v('c2_date');
  }

  // FIX: comparison operators safe inside CDATA block
  if (c1_val <= 0 || c2_val <= 0) { toast('\u26a0 Concentrations must be > 0'); return; }
  if (t2_val <= t1_val)           { toast('\u26a0 t\u2082 must be after t\u2081'); return; }

  ke = Math.log(c1_val / c2_val) / (t2_val - t1_val);

  var t_half    = 0.693 / ke;
  var cmax      = c1_val / Math.exp(-ke * (t1_val - t_inf));
  var cmin      = cmax * Math.exp(-ke * (tau - t_inf));
  var vd        = ((dose / t_inf) * (1 - Math.exp(-ke * t_inf))) /
                  (cmax * ke * (1 - Math.exp(-ke * tau)));
  var clr       = vd * ke;
  var clr_mlmin = clr * 16.67;
  var auc24     = (dose / (ke * vd)) * (24 / tau);

  storedPK = { ke: ke, vd: vd, t_half: t_half, t_inf: t_inf, tau: tau };

  document.getElementById('pk-results').innerHTML =
    '<div class="results-grid">' +
      '<div class="result-item">' +
        '<div class="r-label">Elimination Rate Constant (k<sub>e</sub>)</div>' +
        '<div class="r-value">' + ke.toFixed(4) + '</div>' +
        '<div class="r-unit">hr\u207b\u00b9</div>' +
      '</div>' +
      '<div class="result-item">' +
        '<div class="r-label">Elimination Half-Life (t<sub>\u00bd</sub>)</div>' +
        '<div class="r-value">' + t_half.toFixed(2) + '</div>' +
        '<div class="r-unit">hours</div>' +
      '</div>' +
      '<div class="result-item highlight">' +
        '<div class="r-label">Extrapolated Peak (C<sub>max</sub>) at end of infusion (t\u2032=' + t_inf + 'h)</div>' +
        '<div class="r-value">' + cmax.toFixed(2) + '</div>' +
        '<div class="r-unit">mg/L</div>' +
      '</div>' +
      '<div class="result-item highlight">' +
        '<div class="r-label">Extrapolated Trough (C<sub>min</sub>)</div>' +
        '<div class="r-value">' + cmin.toFixed(2) + '</div>' +
        '<div class="r-unit">mg/L</div>' +
      '</div>' +
      '<div class="result-item">' +
        '<div class="r-label">Volume of Distribution (V<sub>d</sub>)</div>' +
        '<div class="r-value">' + vd.toFixed(2) + '</div>' +
        '<div class="r-unit">L</div>' +
      '</div>' +
      '<div class="result-item">' +
        '<div class="r-label">Clearance (Cl<sub>r</sub>)</div>' +
        '<div class="r-value">' + clr.toFixed(2) + '</div>' +
        '<div class="r-unit">L/hr \u00b7 ' + clr_mlmin.toFixed(1) + ' mL/min</div>' +
      '</div>' +
      '<div class="result-item highlight" style="grid-column:1/-1;">' +
        '<div class="r-label">AUC<sub>24</sub></div>' +
        '<div class="r-value">' + auc24.toFixed(1) + '</div>' +
        '<div class="r-unit">mg\u00b7h/L</div>' +
      '</div>' +
    '</div>';

  var times = linspace(t_inf, tau, 300);
  pkChartInstance = renderChart('pkChart', pkChartInstance, [
    {
      label: 'PK Curve',
      data: times.map(function(t) { return { x: t, y: cmax * Math.exp(-ke * (t - t_inf)) }; }),
      borderColor: '#0e7490', borderWidth: 2.5, pointRadius: 0, fill: false
    },
    {
      label: 'Measured Levels',
      data: [{ x: t1_val, y: c1_val }, { x: t2_val, y: c2_val }],
      borderColor: 'transparent', backgroundColor: '#ef4444',
      pointRadius: 6, pointHoverRadius: 8, showLine: false
    }
  ], 'Time (hours)', 'Concentration (mg/L)');

  toast('\u2713 PK parameters calculated. Click \u201cUse Results in Optimization\u201d to transfer them.');
}

// ─────────────────────────────────────────────────
// Transfer PK → Optimization
// ─────────────────────────────────────────────────
function useInOptimization() {
  if (!storedPK.ke) { toast('\u26a0 Calculate PK parameters first.'); return; }
  document.getElementById('ke_opt').value       = storedPK.ke.toFixed(4);
  document.getElementById('vd_opt').value       = storedPK.vd.toFixed(2);
  if (storedPK.t_inf) document.getElementById('t_inf_opt').value    = storedPK.t_inf;
  if (storedPK.tau)   document.getElementById('interval_opt').value = storedPK.tau;

  document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('active'); });
  document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
  document.getElementById('tab-opt').classList.add('active');
  document.querySelectorAll('.tab-btn')[1].classList.add('active');

  toast('\u2713 Patient-specific parameters copied to Dose Optimization tab.');
}

// ─────────────────────────────────────────────────
// Dose Optimization
// ─────────────────────────────────────────────────
function optimizeDose() {
  var ke       = v('ke_opt');
  var vd       = v('vd_opt');
  var t_inf    = v('t_inf_opt');
  var interval = v('interval_opt');
  var mode     = sv('calc_mode');

  var calcPeak   = function(d) { return (d / (vd * ke * t_inf)) * (1 - Math.exp(-ke * t_inf)); };
  var calcTrough = function(pk) { return pk * Math.exp(-ke * (interval - t_inf)); };
  var calcAUC24  = function(d)  { return (d / (ke * vd)) * (24 / interval); };

  var newDose, predPeak, predTrough, predAUC24;

  if (mode === 'auc') {
    var targetAUC = v('target_auc');
    newDose    = targetAUC * ke * vd * (interval / 24);
    predPeak   = calcPeak(newDose);
    predTrough = calcTrough(predPeak);
    predAUC24  = targetAUC;

  } else if (mode === 'peak') {
    var targetCmax = v('target_cmax');
    newDose    = (targetCmax * vd * ke * t_inf) / (1 - Math.exp(-ke * t_inf));
    predPeak   = calcPeak(newDose);
    predTrough = calcTrough(predPeak);
    predAUC24  = calcAUC24(newDose);

  } else {
    newDose    = v('input_dose');
    predPeak   = calcPeak(newDose);
    predTrough = calcTrough(predPeak);
    predAUC24  = calcAUC24(newDose);
  }

  document.getElementById('opt-results').innerHTML =
    '<div class="results-grid">' +
      '<div class="result-item highlight" style="grid-column:1/-1;">' +
        '<div class="r-label">Recommended Dose</div>' +
        '<div class="r-value">' + newDose.toFixed(0) + '</div>' +
        '<div class="r-unit">mg</div>' +
      '</div>' +
      '<div class="result-item">' +
        '<div class="r-label">Predicted Peak (C<sub>max</sub>)</div>' +
        '<div class="r-value">' + predPeak.toFixed(2) + '</div>' +
        '<div class="r-unit">mg/L</div>' +
      '</div>' +
      '<div class="result-item">' +
        '<div class="r-label">Predicted Trough (C<sub>min</sub>)</div>' +
        '<div class="r-value">' + predTrough.toFixed(2) + '</div>' +
        '<div class="r-unit">mg/L</div>' +
      '</div>' +
      '<div class="result-item highlight" style="grid-column:1/-1;">' +
        '<div class="r-label">Predicted AUC<sub>24</sub></div>' +
        '<div class="r-value">' + predAUC24.toFixed(1) + '</div>' +
        '<div class="r-unit">mg\u00b7h/L</div>' +
      '</div>' +
    '</div>';

  var times = linspace(0, interval, 400);
  var concs = times.map(function(t) {
    if (t_inf <= 0)  return predPeak * Math.exp(-ke * t);
    if (t <= t_inf)  return predPeak * (t / t_inf);
    return predPeak * Math.exp(-ke * (t - t_inf));
  });

  optChartInstance = renderChart('optChart', optChartInstance, [
    {
      label: 'Predicted Curve',
      data: times.map(function(t, i) { return { x: t, y: concs[i] }; }),
      borderColor: '#0e7490', borderWidth: 2.5, pointRadius: 0, fill: false
    },
    {
      label: 'Peak = ' + predPeak.toFixed(2) + ' mg/L',
      data: times.map(function(t) { return { x: t, y: predPeak }; }),
      borderColor: '#ef4444', borderWidth: 1.5, borderDash: [6,4], pointRadius: 0, fill: false
    },
    {
      label: 'Trough = ' + predTrough.toFixed(2) + ' mg/L',
      data: times.map(function(t) { return { x: t, y: predTrough }; }),
      borderColor: '#f97316', borderWidth: 1.5, borderDash: [6,4], pointRadius: 0, fill: false
    }
  ], 'Time (hours)', 'Concentration (mg/L)');
}
//]]>
</script>
</body>
